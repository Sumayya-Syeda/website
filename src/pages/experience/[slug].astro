---
import Layout from '../../layouts/Layout.astro';
import Icon from '../../components/Icon.astro';
import { roadmap, type RoadmapStop } from '../../data/roadmap';
import type { Narrative } from '../../data/narrative';
import { withBase } from '../../lib/path';

interface UnifiedItem {
  slug: string;
  title: string;
  role: string;
  location: string;
  period: string;
  blurb: string;
  highlights: string[];
  tags: string[];
  icon: any;
  pastel: string;
  pastelStrong: string;
  isLatest: boolean;
  topLabel: string; // "Currently" or region name
  logo?: string;
  logoFill?: boolean;
  logoBg?: string;
  narrative?: Narrative;
  photos?: { src: string; alt: string; caption?: string }[];
  artifacts?: { label: string; href: string; kind?: string }[];
  type: 'work';
}

export async function getStaticPaths() {
  const work = roadmap.map((stop, i) => {
    const isLatest = i === roadmap.length - 1;
    return {
      slug: stop.slug,
      title: stop.company,
      role: stop.role,
      location: stop.location,
      period: stop.period,
      blurb: stop.blurb,
      highlights: stop.highlights,
      tags: stop.tags,
      icon: stop.icon,
      pastel: stop.pastel,
      pastelStrong: stop.pastelStrong,
      isLatest,
      topLabel: isLatest ? 'Currently' : stop.region,
      logo: stop.logo,
      logoFill: stop.logoFill,
      logoBg: stop.logoBg,
      narrative: stop.narrative,
      photos: stop.photos,
      artifacts: stop.artifacts,
      type: 'work' as const,
    };
  });

  const all = [...work];

  return all.map((item, index) => ({
    params: { slug: item.slug },
    props: {
      item,
      prev: all[(index - 1 + all.length) % all.length],
      next: all[(index + 1) % all.length],
    },
  }));
}

const { item, prev, next } = Astro.props;
const photos = item.photos ?? [];
---

<Layout
  title={`${item.title} — Sumayya Syeda`}
  description={item.blurb}
>
  <article class="max-w-page mx-auto px-6 pt-12 sm:pt-16 pb-24">
    <a
      href={withBase('/experience')}
      class="inline-flex items-center gap-2 text-sm text-ink-muted hover:text-accent no-underline mb-10 transition-colors"
    >
      <span aria-hidden="true">←</span>
      <span>All experience</span>
    </a>

    <header class="mb-12">
      <div class="flex items-start gap-5 mb-5">
        {item.logo && item.logoFill ? (
          <div class="shrink-0 w-14 h-14 rounded-xl overflow-hidden">
            <img
              src={withBase(item.logo)}
              alt={`${item.title} logo`}
              class="w-full h-full object-cover"
            />
          </div>
        ) : item.logo ? (
          <div
            class="shrink-0 w-14 h-14 rounded-xl border flex items-center justify-center p-2"
            style={`background: ${item.logoBg ?? '#ffffff'}; border-color: ${item.logoBg ?? '#e6e3da'};`}
          >
            <img
              src={withBase(item.logo)}
              alt={`${item.title} logo`}
              class="max-w-full max-h-full object-contain"
            />
          </div>
        ) : (
          <div
            class="shrink-0 w-14 h-14 rounded-xl flex items-center justify-center"
            style={`background: ${item.pastel}; color: ${item.pastelStrong};`}
            aria-hidden="true"
          >
            <Icon name={item.icon} size={28} />
          </div>
        )}
        <div class="flex-1 min-w-0">
          <div class="flex flex-wrap items-baseline gap-x-4 gap-y-1 mb-2">
            <span
              class="font-mono text-[11px] uppercase tracking-widest px-2.5 py-0.5 rounded-full"
              style={`background: ${item.pastel}; color: ${item.pastelStrong};`}
            >
              {item.topLabel}
            </span>
            <p class="font-mono text-[11px] text-ink-faint">{item.period}</p>
          </div>
          <h1 class="font-serif text-4xl sm:text-5xl text-ink leading-tight">
            {item.title}
          </h1>
          <p class="text-sm text-ink-muted mt-2">
            {item.role} · {item.location}
          </p>
        </div>
      </div>
    </header>

    {item.highlights.length > 0 && (
      <section class="mb-12">
        <h2 class="font-mono text-xs uppercase tracking-widest text-ink-faint mb-4">
          Highlights
        </h2>
        <ul class="space-y-2">
          {item.highlights.map((h) => (
            <li class="flex gap-3 text-ink/85 leading-relaxed">
              <span
                class="mt-2 shrink-0 w-1.5 h-1.5 rounded-full"
                style={`background: ${item.pastelStrong};`}
                aria-hidden="true"
              ></span>
              <span set:html={h}></span>
            </li>
          ))}
        </ul>
      </section>
    )}

    <!-- Photos -->
    {photos.length > 0 && (
      <section class="mb-14" aria-label="Photos">
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          {photos.map((photo) => (
            <figure>
              <img src={withBase(photo.src)} alt={photo.alt} class="rounded-lg w-full" />
              {photo.caption && (
                <figcaption class="text-xs text-ink-muted mt-2">{photo.caption}</figcaption>
              )}
            </figure>
          ))}
        </div>
      </section>
    )}

    <section class="mb-12">
      <p class="text-lg text-ink/90 leading-relaxed mb-8">{item.blurb}</p>
      {typeof item.narrative === 'string' && (
        <p class="text-lg text-ink/90 leading-relaxed">{item.narrative}</p>
      )}
      {Array.isArray(item.narrative) && item.narrative.map((section) => (
        <div class="mb-8 last:mb-0">
          {section.heading && (
            <h2 class="font-serif text-xl sm:text-2xl text-ink mb-3">{section.heading}</h2>
          )}
          {section.paragraphs?.map((p) => (
            <p class="text-ink/85 leading-relaxed mb-3">{p}</p>
          ))}
          {section.bullets && (
            <ul class="space-y-3 mt-4">
              {section.bullets.map((b) => (
                <li class="flex gap-3 text-ink/85 leading-relaxed">
                  <span
                    class="mt-2 shrink-0 w-1.5 h-1.5 rounded-full"
                    style={`background: ${item.pastelStrong};`}
                    aria-hidden="true"
                  ></span>
                  <span>
                    {b.name && <strong class="text-ink font-semibold">{b.name}</strong>}{b.name && ' — '}{b.text}
                  </span>
                </li>
              ))}
            </ul>
          )}
        </div>
      ))}
    </section>

    <section class="mb-12">
      <h2 class="font-mono text-xs uppercase tracking-widest text-ink-faint mb-4">
        Tools &amp; topics
      </h2>
      <ul class="flex flex-wrap gap-1.5">
        {item.tags.map((tag) => (
          <li
            class="font-mono text-[10px] uppercase tracking-wider px-2 py-0.5 rounded"
            style={`background: ${item.pastel}; color: ${item.pastelStrong};`}
          >
            {tag}
          </li>
        ))}
      </ul>
    </section>

    {item.artifacts && item.artifacts.length > 0 && (
      <section class="mb-14">
        <h2 class="font-mono text-xs uppercase tracking-widest text-ink-faint mb-4">
          Artifacts
        </h2>
        <ul class="space-y-1">
          {item.artifacts.map((a) => (
            <li>
              <a
                href={withBase(a.href)}
                class="group flex items-center gap-3 py-2 text-ink hover:text-accent no-underline transition-colors"
              >
                <span class="font-mono text-[10px] uppercase tracking-widest text-ink-faint w-12">
                  {a.kind ?? 'link'}
                </span>
                <span class="border-b border-paper-line group-hover:border-accent transition-colors">
                  {a.label}
                </span>
                <span aria-hidden="true" class="text-ink-faint group-hover:text-accent transition-colors">→</span>
              </a>
            </li>
          ))}
        </ul>
      </section>
    )}

    <nav class="border-t border-paper-line pt-8 flex flex-col sm:flex-row gap-4 justify-between text-sm">
      <a
        href={withBase(`/experience/${prev.slug}`)}
        class="group no-underline text-ink-muted hover:text-accent transition-colors"
      >
        <span class="font-mono text-[10px] uppercase tracking-widest block mb-1">← Previous</span>
        <span class="font-serif text-base text-ink group-hover:text-accent transition-colors">
          {prev.title}
        </span>
      </a>
      <a
        href={withBase(`/experience/${next.slug}`)}
        class="group no-underline text-ink-muted hover:text-accent transition-colors text-right"
      >
        <span class="font-mono text-[10px] uppercase tracking-widest block mb-1">Next →</span>
        <span class="font-serif text-base text-ink group-hover:text-accent transition-colors">
          {next.title}
        </span>
      </a>
    </nav>
  </article>
</Layout>
