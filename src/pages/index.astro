---
import Layout from '../layouts/Layout.astro';
import WindingRoad from '../components/WindingRoad.astro';
import { roadmap, regions } from '../data/roadmap';
import { withBase } from '../lib/path';
---

<Layout
  title="Sumayya Syeda — Systems Engineer"
  description="Sumayya Syeda — systems and performance engineer at Apple, working on streaming media internals."
>
  <!-- Hero / About -->
  <section class="max-w-page mx-auto px-6 pt-16 sm:pt-24 pb-12 sm:pb-16">
    <div class="flex flex-col sm:flex-row gap-6 sm:gap-10 items-center">
      <img
        src={withBase('/profile.jpg')}
        alt="Sumayya Syeda"
        class="w-[9.375rem] h-[9.375rem] sm:w-[10.9375rem] sm:h-[10.9375rem] shrink-0 rounded-full object-cover border border-paper-line"
      />

      <div class="max-w-prose">
        <p class="font-mono text-xs uppercase tracking-widest text-ink-faint mb-2">
          Systems Engineer · Apple
        </p>
        <h1 class="font-serif text-4xl sm:text-5xl leading-tight text-ink mb-4">
          Sumayya Syeda
        </h1>
        <p class="text-lg text-ink/90 leading-relaxed mb-5">
          CMU '24, ECE + Robotics. I build low-level systems software —
          currently on Apple's streaming media team in San Diego.
        </p>
      </div>
    </div>
  </section>

  <!-- Roadmap -->
  <section id="roadmap" class="max-w-page mx-auto px-6 pb-24">
    <header class="mb-6 sm:mb-8 reveal flex flex-wrap items-baseline justify-between gap-4">
      <div>
        <p class="font-mono text-xs uppercase tracking-widest text-ink-faint mb-2">
          The road so far
        </p>
        <h2 class="font-serif text-2xl sm:text-3xl text-ink leading-tight">
          A map of where I've been
        </h2>
      </div>
      <p class="text-sm text-ink-muted max-w-xs">
        Pins sit at each location, in chronological order along the road.
        <span class="text-ink-faint">Click any pin to read the full story →</span>
      </p>
    </header>

    <div class="reveal">
      <WindingRoad stops={roadmap} regions={regions} />
    </div>
  </section>
</Layout>
